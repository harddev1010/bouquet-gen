{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx server/index.ts",
    "dev:watch": "nodemon --watch server --ext ts,tsx --exec tsx server/index.ts",
    "build": "tsx script/build.ts",
    "start": "cross-env NODE_ENV=production node dist/index.cjs",
    "check": "tsc"
  },
  "dependencies": {
    "express": "^5.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "20.19.27",
    "cross-env": "^10.1.0",
    "esbuild": "^0.25.0",
    "nodemon": "^3.1.11",
    "tsx": "^4.20.5",
    "typescript": "5.6.3"
  }
}
